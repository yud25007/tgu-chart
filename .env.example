# Copy this file to .env and fill in real values locally or on the server.

# Required. Web login password.
AUTH_PASSWORD=change-this-password

# Required. Admin panel password.
ADMIN_PASSWORD=change-this-admin-password

# Optional but recommended in production.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET=

# Optional. Defaults to Asia/Shanghai.
APP_TIMEZONE=Asia/Shanghai

# Required only when running the Cloudflare tunnel container.
TGU_CHART_TUNNEL_TOKEN=
